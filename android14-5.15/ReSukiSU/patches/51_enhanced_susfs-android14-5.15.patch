+static void susfs_try_register_hidden_name(const char *pathname)
+{
+	const char *prefix;
+	const char *basename;
+	int namlen;
+	uid_t owner_uid = 0;
+	struct path data_path;
+	char lookup_buf[256];
+
+	prefix = strstr(pathname, "/Android/data/");
+	if (prefix) {
+		basename = prefix + 14;
+	} else {
+		prefix = strstr(pathname, "/Android/obb/");
+		if (!prefix)
+			return;
+		basename = prefix + 13;
+	}
+	if (!*basename)
+		return;
+	namlen = 0;
